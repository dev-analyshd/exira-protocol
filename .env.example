# EXIRA Protocol Environment Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/exira

# Server
PORT=5000
NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# Blockchain
PRIVATE_KEY=0x_YOUR_TESTNET_PRIVATE_KEY_HERE
X_LAYER_RPC=https://testrpc.xlayer.tech

# Contract Addresses (populated after deployment)
EXIRA_ORACLE_ADDRESS=
EXIRA_REGISTRY_ADDRESS=
EXIRA_ESCROW_ADDRESS=
EXIRA_TOKEN_ADDRESS=

# OKX Integration
OKX_API_KEY=
OKX_API_SECRET=
OKLINK_API_KEY=

# Webhooks
WEBHOOK_SECRET=your_webhook_secret_here
